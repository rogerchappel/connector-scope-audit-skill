{
  "name": "connector-scope-audit-skill",
  "version": "0.1.0",
  "description": "Audit connector action plans against local scope and approval policy.",
  "type": "module",
  "bin": {
    "connector-scope-audit": "./bin/connector-scope-audit.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check-package.js",
    "build": "node scripts/check-package.js",
    "smoke": "node bin/connector-scope-audit.js audit fixtures/action-plan.json --policy fixtures/policy.json --json",
    "package:smoke": "node scripts/package-smoke.mjs",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke",
    "lint": "npm run check"
  },
  "keywords": [
    "agent-skills",
    "connectors",
    "dry-run",
    "approval"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "examples",
    "fixtures",
    "scripts",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/connector-scope-audit-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/connector-scope-audit-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/connector-scope-audit-skill#readme"
}
